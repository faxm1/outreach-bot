# Telegram
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_ALLOWED_CHAT_ID=YOUR_NUMERIC_CHAT_ID_HERE

# Sender
SENDER_NAME=Your Full Name
SENDER_EMAIL=your_email@gmail.com
CV_PDF_PATH=C:/Users/YourName/Documents/YourCV.pdf

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_USE_TLS=true
SMTP_USE_AUTH=true

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=huihui_ai/deepseek-r1-abliterated:14b

# Database / safety
DB_PATH=outreach.db
MAX_EMAILS_PER_HOUR=10
MAX_EMAILS_PER_DAY=50
DEDUP_WINDOW_DAYS=30
CONFIRMATION_TIMEOUT_HOURS=12
MAX_CV_SIZE_MB=5

# Send window / retries
SEND_TIMEZONE=Asia/Riyadh
SEND_WINDOW_START=8
SEND_WINDOW_END=18
MAX_RETRIES=3
RETRY_BACKOFF_MINUTES=5,30,120
RATE_LIMIT_REQUEUE_MINUTES=10
